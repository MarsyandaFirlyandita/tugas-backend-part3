      "name": "Thrift API",
      "item": [
        {
          "name": "CREATE NEW PRODUCT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Product created\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "\r",
                  "    pm.expect(json).to.have.property(\"id\");\r",
                  "    pm.expect(json).to.have.property(\"name\");\r",
                  "    pm.expect(json).to.have.property(\"price\");\r",
                  "    pm.expect(json).to.have.property(\"condition\");\r",
                  "    pm.expect(json).to.have.property(\"stock\");\r",
                  "\r",
                  "    pm.environment.set(\"product_id\", json.id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"Jaket Uniqlo\",\r\n    \"description\": \"Jaket Uniqlo vintage keren\",\r\n    \"price\": 190000,\r\n    \"condition\": \"baik\",\r\n    \"size\": \"L\",\r\n    \"brand\": \"Uniqlo\",\r\n    \"stock\": 1\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/products",
              "host": [
                "{{url}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        },
